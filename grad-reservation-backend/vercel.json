{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/scan",    "destination": "/server.js" },
    { "source": "/api/:path*", "destination": "/server.js" },
    { "source": "/(.*)",    "destination": "/server.js" }
  ]
}